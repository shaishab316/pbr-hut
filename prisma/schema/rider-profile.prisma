model RiderProfile {
  userId String @id

  latitude  Float?
  longitude Float?
  h3Index   String?

  nidFrontUrl     String?
  nidBackUrl      String?
  nidStatus       NidStatus @default(NOT_SUBMITTED)
  verifiedAt      DateTime?
  rejectionReason String? //? only set when REJECTED

  isAvailable Boolean @default(false)
  isBusy      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([h3Index])
  @@index([isAvailable, isBusy, nidStatus])
  @@map("rider_profiles")
}
