model RiderProfile {
  userId String @id 

  geohash String? //? city-level

  nidFrontUrl     String?
  nidBackUrl      String?
  nidStatus       NidStatus @default(PENDING)
  verifiedAt      DateTime?
  rejectionReason String? //? only set when REJECTED

  isAvailable Boolean @default(false)
  isBusy      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([geohash])
  @@index([isAvailable, isBusy, nidStatus])
  @@map("rider_profiles")
}

enum NidStatus {
  PENDING
  VERIFIED
  REJECTED
}
