model User {
  id           String  @id @default(ulid())
  email        String? @unique
  phone        String? @unique
  passwordHash String?

  name String?

  role     UserRole @default(CUSTOMER)
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  RIDER
}
