# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/pbr_hut_db

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=your_super_secret_key_minimum_32_characters_long_here_12345
JWT_EXPIRES_IN=7d

# ========================================
# Stripe Payment Gateway
# ========================================
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnop
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdefghijklmnop
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnop

# ========================================
# Cloudinary Media Management
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=1234567890123456
CLOUDINARY_API_SECRET=your_api_secret_key_here

# ========================================
# Email Configuration (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@pbr-hut.com
SMTP_FROM_NAME=PBR Hut

# ========================================
# Admin Credentials (Initial Setup)
# ========================================
ADMIN_EMAIL=admin@pbr-hut.com
ADMIN_PASSWORD=Admin@12345

# ========================================
# Logging
# ========================================
LOG_LEVEL=log