model Restaurant {
  id   String @id @default(uuid())
  name String

  address   String
  latitude  Float?
  longitude Float?
  h3Index   String?

  openingHour String
  closingHour String

  deliveryRadius  Float
  baseDeliveryFee Decimal @db.Decimal(10, 2)

  minimumOrderAmountCOD Decimal @db.Decimal(10, 2)

  isCODEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Index])
  @@map("restaurants")
}
