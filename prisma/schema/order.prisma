model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)

  /// Rider fulfilling this delivery (delivery orders only)
  assignedRiderId String?
  assignedRider   User?   @relation("AssignedRider", fields: [assignedRiderId], references: [id], onDelete: SetNull)

  /// H3 cell (res 7, same as `RiderProfile.h3Index`) at drop-off lat/lng — for O(1) rider pool lookup
  h3Index String?

  /// Short public reference for receipts and support (e.g. POGK4j524)
  orderNumber      String @unique
  /// 4-digit code for the customer to share with the rider
  confirmationCode String

  type          OrderType
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(UNPAID)

  deliveryTiming DeliveryTiming @default(NOW)
  scheduledAt    DateTime? // null when timing = NOW

  estimatedArrivalAt DateTime? // ETA shown in the app while the order is active
  deliveredAt        DateTime? // set when status becomes DELIVERED or PICKED_UP

  // Bill breakdown — snapshots from cart at checkout time
  itemsTotal     Decimal @db.Decimal(10, 2)
  deliveryCharge Decimal @default(0) @db.Decimal(10, 2) // 0 for PICKUP
  discount       Decimal @default(0) @db.Decimal(10, 2) // $1000 >= 1% discount
  taxes          Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  deliveryAddress OrderDeliveryAddress? // null for PICKUP
  billingAddress  OrderBillingAddress? // usually set for CARD; optional snapshot for COD
  items           OrderItem[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  riderEarning RiderEarning?
  declines     OrderDecline[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([h3Index])
  @@index([assignedRiderId])
  @@index([h3Index, status])
  @@map("orders")
}

model OrderDeliveryAddress {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// Map pin / street title (e.g. road name)
  locationLabel String?

  name           String
  phoneNumber    String
  address        String
  buildingDetail String?
  latitude       Float?
  longitude      Float?

  @@map("order_delivery_addresses")
}

model OrderBillingAddress {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  country      String
  addressLine1 String
  addressLine2 String?
  suburb       String
  city         String
  postalCode   String
  state        String

  @@map("order_billing_addresses")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Keep FK for analytics, but nullable — item may be soft-deleted later
  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)

  // Snapshots — source of truth for receipts
  itemName String
  imageUrl String

  quantity   Int     @default(1)
  customNote String?

  // Selected option snapshots
  sizeName       String?
  sideOptionName String?
  sizePrice      Decimal? @db.Decimal(10, 2)
  sidePrice      Decimal? @default(0) @db.Decimal(10, 2)

  unitPrice  Decimal @db.Decimal(10, 2) // sizePrice + sidePrice + sum(extras)
  totalPrice Decimal @db.Decimal(10, 2) // unitPrice × quantity

  extras OrderItemExtra[]

  @@index([orderId])
  @@map("order_items")
}

model OrderItemExtra {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  extraName String // snapshot — "Corns & Capsicum"
  price     Decimal @db.Decimal(10, 2)

  @@map("order_item_extras")
}

model OrderDecline {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId String
  rider   User   @relation("DeclinedOrders", fields: [riderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([orderId, riderId])
  @@index([riderId])
  @@map("order_declines")
}
